{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationMap": false,
    "outDir": "types",
    "rootDir": "lib",
    "skipLibCheck": true
  },
  "exclude": ["types", "examples", "node_modules"],
  "include": [
    "declarations.d.ts",
    "declarations/*.d.ts",
    "schemas/**/*.json",
    "lib/**/*.js"
  ]
}
