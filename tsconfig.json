{
  "compilerOptions": {
    "target": "ES2024",
    "module": "nodenext",
    "lib": ["es2025", "dom"],
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": true,
    "types": ["node"],
    "esModuleInterop": true,
    "paths": {
      "webpack-sources/types": ["./node_modules/webpack-sources/types.d.ts"]
    }
  },
  "include": [
    "declarations.d.ts",
    "declarations/*.d.ts",
    "schemas/**/*.json",
    "bin/*.js",
    "lib/**/*.js",
    "tooling/**/*.js",
    "setup/**/*.js",
    "examples/*.js",
    "examples/**/webpack.config.js",
    "examples/**/webpack.config.cjs",
    "examples/**/webpack.config.mjs",
    "examples/**/test.filter.js",
    "examples/**/internals/*.js"
  ]
}
