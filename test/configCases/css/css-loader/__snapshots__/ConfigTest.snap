.nesting_module_css-notice {
	width: 90%;
	justify-content: center;
	border-radius: 1rem;
	border: black solid 2px;
	background-color: #ffc107;
	color: black;
	padding: 1rem;

	.nesting_module_css-notice-heading:before {
		/* equivalent to \`.notice .notice-heading:before\` */
		content: \\"ℹ︎ \\";
	}

	&.nesting_module_css-warning {
		/* equivalent to \`.notice.warning\` */
		background-color: #d81b60;
		border-color: #d81b60;
