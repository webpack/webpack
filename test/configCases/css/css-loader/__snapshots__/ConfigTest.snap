	&.nesting_module_css-success {
		/* equivalent to \`.notice.success\` */
		background-color: #004d40;
		border-color: #004d40;
		color: white;

		.nesting_module_css-success-heading:before {
			/* equivalent to \`.notice.success .success-heading:before\` */
			content: \\"✓ \\";
		}
	}
