	var: var(--my-app-style_module_css-main-color);
	var1: var(--my-app-style_module_css-foo);
	var2: var(--my-app-style_module_css-FOO);
	content: \\" (\\" var(--my-app-style_module_css-external-link) \\")\\";
	var3: var(--my-app-style_module_css-main-color, blue);
