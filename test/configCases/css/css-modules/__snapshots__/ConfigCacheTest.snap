	background-color: --my-app-style_module_css-transparent-local(var(--base-color), 0.8);
	background-color: --transparent-global(var(--base-color), 0.8);
}

:root {
	--mode: sharp;
}

.apply-sharp {
	border-radius: if(style(--mode: sharp): 0px; else: revert-rule);
}

@color-profile --swop5c {
