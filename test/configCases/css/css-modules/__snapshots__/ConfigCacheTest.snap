@property --progress {
	syntax: \\"<percentage>\\";
	inherits: false;
	initial-value: 25%;
}

.bar {
	display: inline-block;
	--progress: 25%;
	width: 100%;
	height: 5px;
	background: linear-gradient(
		to right,
		#00d230 var(--progress),
		black var(--progress)
	);
	animation: progressAnimation 2.5s ease infinite;
}

@keyframes progressAnimation {
	to {
		--progress: 100%;
	}
}

