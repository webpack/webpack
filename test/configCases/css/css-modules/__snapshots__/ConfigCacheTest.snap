.my-app-style_module_css-var {
	--my-app-style_module_css-main-color: black;
	--my-app-style_module_css-FOO: 10px;
	--my-app-style_module_css-foo: 10px;
	--my-app-style_module_css-bar: calc(var(--my-app-style_module_css-foo) + 10px);
	--my-app-style_module_css-accent-background: linear-gradient(to top, var(--my-app-style_module_css-main-color), white);
