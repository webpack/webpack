@function --my-app-style_module_css-max-plus-x(--my-app-style_module_css-list <length>#, --my-app-style_module_css-x <length>) {
	result: calc(max(var(--my-app-style_module_css-list)) + var(--my-app-style_module_css-x));
}

div {
	width: --my-app-style_module_css-max-plus-x({1px, 7px, 2px}, 3px); /* 10px */
}

@function --my-app-style_module_css-anim-1s(--my-app-style_module_css-animation, --my-app-style_module_css-count) {
	--my-app-style_module_css-duration: 1s;
	--my-app-style_module_css-easing: linear;
	result: var(--my-app-style_module_css-animation) var(--my-app-style_module_css-duration) var(--my-app-style_module_css-count) var(--my-app-style_module_css-easing);
}

