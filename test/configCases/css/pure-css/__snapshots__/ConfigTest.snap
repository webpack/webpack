			}
		}
	}

	/* Define a complete alternate theme nested inside the container */
	&.is-dark-theme {
		/* These variables are scoped only to elements within this specific container */
		--accordion-bg: #333;
		--accordion-border: #555;
		--accordion-text: #eee;
		--accordion-accent: #2ecc71; /* A new accent color for the dark theme */
	}
}

.media-object {
